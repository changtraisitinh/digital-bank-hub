<!--
    This file defines class loading policy for the Usage Data Receiver webapp.
    Matches WSO2 APIM Publisher API configuration.
-->
<Classloading xmlns="http://wso2.org/projects/as/classloading">

    <!-- Child-first classloading (default) -->
    <ParentFirst>true</ParentFirst>

    <!--
        Environments required by this webapp:
        - CXF3: Apache CXF 3.x for JAX-RS REST API support (provided by Carbon)
        - Carbon: WSO2 Carbon framework (for OSGi, datasources, logging)

        Using Carbon's CXF3 environment to keep WAR size small (< 2MB).
    -->
    <Environments>CXF3, Carbon</Environments>
</Classloading>

